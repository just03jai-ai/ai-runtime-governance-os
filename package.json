{
  "name": "ai-runtime-governance-os",
  "version": "1.0.0",
  "description": "AI Runtime Governance OS is an AI-native operational governance platform that continuously inspects, validates, verifies, analyzes, and monitors production UI systems using runtime evidence, governance contracts, and design-system intelligence to deliver continuous operational observability and release confidence.",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "build": "tsc --noEmit",
    "cli": "tsx src/cli/cli.ts",
    "audit": "tsx src/cli/cli.ts audit",
    "execute:example": "tsx src/orchestration/example-execution-flow.ts",
    "prototype": "tsx src/server/prototype-server.ts",
    "report": "tsx src/cli/cli.ts report",
    "test:unit": "vitest run",
    "validate": "tsx src/cli/cli.ts validate",
    "verify": "tsx src/cli/cli.ts verify",
    "test": "npm run build && vitest run"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/just03jai-ai/ai-runtime-governance-os.git"
  },
